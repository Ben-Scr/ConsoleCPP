<?xml version="1.0"?>
<package>
  <metadata>
    <id>ConsoleCPP</id>
    <version>1.0.0</version>
    <authors>Ben</authors>
    <owners>Ben</owners>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>A C++ console utility library similar to the C# console syntax</description>
    <icon>icon.png</icon>
    <readme>README.md</readme>
    <license type="file">LICENSE.txt</license>
  </metadata>

  <files>
    <file src="Build\ConsoleCPP.lib" target="Lib\Native" />
    <file src="ConsoleCPP\Include\*.hpp" target="Build\Native\Include" />
    <file src="icon.png" target="" />
    <file src="README.md" target="" />
    <file src="LICENSE.txt" target="" />
  </files>
</package>
