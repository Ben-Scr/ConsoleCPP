<?xml version="1.0"?>
<package>
	<metadata>
		<id>ConsoleCPP</id>
		<version>1.0.1</version>
		<authors>Ben Schneider</authors>
		<owners>Ben Schneider</owners>

		<summary>Modern C++ console helper library</summary>

		<projectUrl>https://github.com/Ben-Scr/ConsoleCPP</projectUrl>

		<tags>Console;CPP;Library;</tags>

		<requireLicenseAcceptance>false</requireLicenseAcceptance>
		<description>A C++ console utility library similar to the C# console syntax</description>
		<icon>icon.png</icon>
		<readme>README.md</readme>
		<license type="file">LICENSE.txt</license>
	</metadata>

	<files>
		<file src="Build\ConsoleCPP.lib" target="Lib\Native" />
		<file src="ConsoleCPP\Include\*.hpp" target="Build\Native\Include" />
		<file src="ConsoleCPP.props" target="Build\Native" />
		
		<file src="icon.png" target="" />
		<file src="README.md" target="" />
		<file src="LICENSE.txt" target="" />
	</files>
</package>
